# Cloudflare Pages environment variables.
# Set these as encrypted secrets in the CF Pages dashboard:
#   https://dash.cloudflare.com → Workers & Pages → carmennghealing → Settings → Environment variables

# Resend (https://resend.com/api-keys) — used to email the contact-form submission
# to Carmen via a Cloudflare Pages Function. Without this, /api/contact returns 500.
RESEND_API_KEY=

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile → your site → Keys)
# Site key is public, gets inlined into the page at build time (Vite PUBLIC_ prefix).
# Secret key is server-side only, used by /api/contact to verify the widget token.
# If both are unset the widget is hidden and verification is skipped (dev only).
PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# Optional overrides for the contact-form recipient and sender.
# Defaults are used if unset: hello@carmennghealing.com / Carmen Ng Healing <noreply@carmennghealing.com>
# The FROM address must be on a domain verified in Resend.
CONTACT_TO_EMAIL=
CONTACT_FROM_ADDRESS=
