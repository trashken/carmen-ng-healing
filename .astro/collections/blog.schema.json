{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "jp": {
          "type": "string"
        },
        "zh": {
          "default": "",
          "type": "string"
        }
      },
      "required": [
        "en",
        "jp"
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "article",
        "news"
      ]
    },
    "cover": {
      "type": "string"
    },
    "video": {
      "type": "string"
    },
    "body_en": {
      "default": "",
      "type": "string"
    },
    "body_jp": {
      "type": "string"
    },
    "body_zh": {
      "default": "",
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "slug",
    "title",
    "date",
    "category",
    "body_jp"
  ]
}