{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "jp",
        "en",
        "zh"
      ]
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "service",
    "lang",
    "rating"
  ]
}