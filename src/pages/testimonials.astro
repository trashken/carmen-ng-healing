---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
// Render each entry's Markdown body to HTML.
const rendered = await Promise.all(
  allTestimonials.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

// Order: same as the original page (alphabetical by name within the
// original grouping was the source's order; we'll just keep file order).
const langBadge: Record<'jp' | 'en' | 'zh', string> = {
  jp: '日本語',
  en: 'English',
  zh: '中文',
};
---

<Layout title="Testimonials" description="Read what clients say about their healing journey with Carmen Ng.">
  <section class="py-24 bg-gradient-to-b from-blush to-warm-white">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-rose font-serif text-center text-lg italic mb-2">Client Stories</p>
      <h1 class="section-title">Testimonials</h1>
      <p class="section-subtitle">The greatest honour of this work is witnessing transformation. Here are some words from those who've walked this path.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {rendered.map(({ entry, Content }) => (
          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full bg-rose/10 text-rose">
                {entry.data.service}
              </span>
              <span class="text-[10px] uppercase tracking-wider text-ink-light/50">
                {langBadge[entry.data.lang]}
              </span>
            </div>
            <div class="text-rose/30 text-4xl font-serif leading-none mb-2">"</div>
            <div class="text-ink-light text-sm leading-relaxed mb-6 italic whitespace-pre-line">
              <Content />
            </div>
            <div class="flex items-center justify-between mt-auto border-t border-rose/10 pt-4">
              <span class="text-sm font-medium">— {entry.data.name}</span>
              <div class="flex gap-0.5 text-rose text-xs">{'★'.repeat(entry.data.rating)}{'☆'.repeat(5 - entry.data.rating)}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
