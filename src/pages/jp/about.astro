---
import Layout from '../../../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import AboutContent from '../../../components/AboutContent.astro';
import { getDictionary } from '../../../i18n';

const t = getDictionary('jp');
const entry = (await getEntry('about', 'main'))!;
const title = entry.data.title_jp;
const description = entry.data.body_jp.split('\n')[0].slice(0, 160);
---

<Layout title={`${title} | ${t.meta.siteName}`} description={description} locale="jp">
  <article class="max-w-6xl mx-auto px-6 py-12">
    <AboutContent locale="jp" entry={entry} />
  </article>
</Layout>
