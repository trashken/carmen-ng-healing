---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getDictionary, type Locale } from '../../../i18n';

const locale: Locale = 'jp';
const t = getDictionary(locale);

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const formatDate = (iso: Date) =>
  iso.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${t.nav.blog} | ${t.meta.siteName}`} locale={locale}>
  <section class="py-24 bg-gradient-to-b from-blush to-warm-white">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-rose font-serif text-center text-lg italic mb-2">{t.nav.blog}</p>
      <h1 class="section-title">{t.nav.blog}</h1>
      <p class="section-subtitle">癒し、スピリチュアル、マインドフル・ライフについての考察。</p>

      <div class="flex justify-center gap-4 mb-12">
        <a id="tab-all" href="/jp/blog" class="tab px-6 py-2 rounded-full bg-rose text-white text-sm">全ての記事</a>
        <a id="tab-news" href="/jp/blog?category=news" class="tab px-6 py-2 rounded-full border border-rose/30 text-ink-light text-sm hover:bg-rose/5">お知らせ</a>
      </div>

      <div id="post-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <article class="card group" data-category={post.data.category}>
            <a href={`/jp/blog/${post.data.slug}`} class="block">
              <div class="w-full h-44 rounded-xl mb-5 overflow-hidden bg-gradient-to-br from-sky-light/40 to-lavender-light/40 relative">
                {post.data.cover
                  ? <img src={post.data.cover} alt="" loading="lazy" class="w-full h-full object-cover" />
                  : <div class="w-full h-full flex items-center justify-center">
                      {post.data.video
                        ? <span class="text-3xl opacity-30">▶</span>
                        : <span class="text-3xl opacity-20">✦</span>
                      }
                    </div>
                }
                {post.data.video && (
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <span class="w-12 h-12 rounded-full bg-ink/60 text-white text-2xl flex items-center justify-center">▶</span>
                  </div>
                )}
              </div>
              <p class="text-xs text-rose tracking-wider uppercase mb-2">
                {post.data.category === 'news' ? 'お知らせ' : '記事'}
              </p>
              <h2 class="font-serif text-lg mb-2 group-hover:text-rose transition-colors">
                {post.data.title.jp}
              </h2>
              <p class="text-ink-light text-sm leading-relaxed mb-4 line-clamp-3 whitespace-pre-line">
                {post.data.body_jp.split('\n')[0].slice(0, 100)}…
              </p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-ink-light/60">{formatDate(post.data.date)}</span>
                <span class="text-rose text-sm group-hover:underline">続きを読む →</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <p id="empty-state" class="hidden text-center text-ink-light/60 italic mt-12">
        このカテゴリーの記事はまだありません。
      </p>
    </div>
  </section>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const category = params.get('category');
  const allTab = document.getElementById('tab-all');
  const newsTab = document.getElementById('tab-news');
  const grid = document.getElementById('post-grid');
  const empty = document.getElementById('empty-state');

  if (grid && allTab && newsTab) {
    if (category === 'news') {
      grid.querySelectorAll<HTMLElement>('[data-category]').forEach((el) => {
        el.style.display = el.dataset.category === 'news' ? '' : 'none';
      });
      allTab.className = 'tab px-6 py-2 rounded-full border border-rose/30 text-ink-light text-sm hover:bg-rose/5';
      newsTab.className = 'tab px-6 py-2 rounded-full bg-rose text-white text-sm';
    } else {
      grid.querySelectorAll<HTMLElement>('[data-category]').forEach((el) => {
        el.style.display = '';
      });
    }

    if (empty) {
      const visible = grid.querySelectorAll<HTMLElement>('[data-category]:not([style*="display: none"])').length;
      empty.style.display = visible === 0 ? '' : 'none';
    }
  }
</script>
