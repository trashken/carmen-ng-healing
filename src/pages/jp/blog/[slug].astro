---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getDictionary, type Locale } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const locale: Locale = 'jp';
const t = getDictionary(locale);

const title = post.data.title_jp;
const body = post.data.body_jp;
const bodyParagraphs = body.split('\n').map((p: string) => p.trim()).filter(Boolean);

const formatDate = (iso: Date) =>
  iso.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${title} | ${t.meta.siteName}`} description={bodyParagraphs[0]?.slice(0, 160)} locale={locale}>
  <article class="py-20 bg-gradient-to-b from-blush to-warm-white">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/jp/blog" class="inline-flex items-center text-sm text-rose hover:underline mb-8">← ブログ一覧へ</a>

      {post.data.cover && (
        <div class="mb-8 rounded-2xl overflow-hidden shadow-lg">
          <img src={post.data.cover} alt="" class="w-full h-auto" />
        </div>
      )}

      {post.data.video && (
        <div class="mb-8 rounded-2xl overflow-hidden shadow-lg bg-ink">
          <video controls class="w-full" preload="metadata" poster={post.data.cover ?? '/favicon.svg'}>
            <source src={post.data.video} type="video/mp4" />
            お使いのブラウザは動画再生に対応していません。
          </video>
        </div>
      )}

      <header class="mb-10">
        <p class="text-xs text-rose tracking-wider uppercase mb-3">
          {post.data.category === 'news' ? 'お知らせ' : '記事'}
        </p>
        <h1 class="font-serif text-3xl md:text-5xl text-ink mb-4 leading-tight">{title}</h1>
        <p class="text-sm text-ink-light/70">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        </p>
      </header>

      <div class="prose prose-lg max-w-none text-ink-light leading-relaxed space-y-5 whitespace-pre-line">
        {body}
      </div>

      <div class="mt-16 pt-8 border-t border-rose/20 flex flex-col sm:flex-row gap-3 justify-between items-start sm:items-center">
        <a href="/jp/blog" class="btn-outline text-xs px-6 py-2">全ての記事</a>
        <div class="flex gap-2 text-xs">
          <a href={`/en/blog/${post.data.slug}`} class="px-3 py-1 rounded-full border border-rose/30 text-ink-light hover:bg-rose/5">English</a>
          <a href={`/zh/blog/${post.data.slug}`} class="px-3 py-1 rounded-full border border-rose/30 text-ink-light hover:bg-rose/5">中文</a>
        </div>
      </div>
    </div>
  </article>
</Layout>
