---
import Layout from '../../layouts/Layout.astro';
import HomeContent from '../../components/HomeContent.astro';
import { getDictionary, type Locale } from '../../i18n';

const locale: Locale = 'jp';
const t = getDictionary(locale);
---

<Layout title={`${t.meta.homeTitle} | ${t.meta.siteName}`} description={t.meta.defaultDescription} locale={locale} transparentNav>
  <HomeContent locale="jp" />
</Layout>
