---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ServiceDetail from '../../../components/ServiceDetail.astro';
import { getDictionary } from '../../../i18n';

export async function getStaticPaths() {
  const all = await getCollection('services');
  return all
    .filter((entry) =>
      entry.data.intro?.en !== '' ||
      entry.data.serviceBody?.en !== '' ||
      entry.data.offerings.length > 0
    )
    .map((entry) => ({
      params: { slug: entry.id.replace(/\.md$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const t = getDictionary('zh');
const title = entry.data.title.zh || entry.data.title.jp;
const description = entry.data.desc.zh || entry.data.desc.jp;
---

<Layout title={`${title} | ${t.meta.siteName}`} description={description} locale="zh">
  <article class="max-w-6xl mx-auto px-6 py-12">
    <ServiceDetail locale="zh" entry={entry} />
  </article>
</Layout>
