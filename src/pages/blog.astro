---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    title: 'The Power of Sound Healing in Modern Life',
    excerpt: 'How ancient sound frequencies can help us navigate the chaos of our modern world and restore inner balance.',
    date: 'March 15, 2026',
    category: 'News',
    slug: 'power-of-sound-healing',
  },
  {
    title: 'Understanding Your Energy Body',
    excerpt: 'A beginner\'s guide to the seven chakras and how they influence your physical and emotional wellbeing.',
    date: 'February 28, 2026',
    category: 'All Posts',
    slug: 'understanding-energy-body',
  },
  {
    title: 'Spring Equinox — A Time for Renewal',
    excerpt: 'Rituals and practices to align with the energy of spring and plant seeds for the season ahead.',
    date: 'February 10, 2026',
    category: 'All Posts',
    slug: 'spring-equinox-renewal',
  },
  {
    title: 'Crystal Healing 101: Getting Started',
    excerpt: 'An introduction to working with crystals — how to choose, cleanse, and attune to their energies.',
    date: 'January 22, 2026',
    category: 'All Posts',
    slug: 'crystal-healing-101',
  },
  {
    title: 'The Art of Mindful Breathing',
    excerpt: 'Simple breathwork techniques to calm your nervous system and find peace in stressful moments.',
    date: 'January 5, 2026',
    category: 'All Posts',
    slug: 'mindful-breathing',
  },
  {
    title: 'Winter Solstice Reflection',
    excerpt: 'Honouring the darkness as we welcome the return of light — a meditation for the solstice season.',
    date: 'December 21, 2025',
    category: 'News',
    slug: 'winter-solstice',
  },
];
---

<Layout title="Blog" description="Insights on energy healing, sound therapy, meditation, and spiritual growth from Carmen Ng.">
  <section class="py-24 bg-gradient-to-b from-blush to-warm-white">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-rose font-serif text-center text-lg italic mb-2">Thoughts & Insights</p>
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">Reflections on healing, spirituality, and mindful living.</p>

      <!-- Category tabs -->
      <div class="flex justify-center gap-4 mb-12">
        <a href="/blog" class="px-6 py-2 rounded-full bg-rose text-white text-sm">All Posts</a>
        <a href="/blog?category=news" class="px-6 py-2 rounded-full border border-rose/30 text-ink-light text-sm hover:bg-rose/5">News</a>
      </div>

      <!-- Post grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <article class="card group cursor-pointer">
            <div class="w-full h-44 bg-gradient-to-br from-sky-light/40 to-lavender-light/40 rounded-xl mb-5 flex items-center justify-center">
              <span class="text-3xl opacity-20">✦</span>
            </div>
            <p class="text-xs text-rose tracking-wider uppercase mb-2">{post.category === 'News' ? 'News & Events' : 'Articles'}</p>
            <h2 class="font-serif text-lg mb-2 group-hover:text-rose transition-colors">{post.title}</h2>
            <p class="text-ink-light text-sm leading-relaxed mb-4">{post.excerpt}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-ink-light/60">{post.date}</span>
              <a href={`/blog/${post.slug}`} class="text-rose text-sm hover:underline">Read more →</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex justify-center mt-12 gap-2">
        <span class="w-10 h-10 rounded-full bg-rose text-white flex items-center justify-center text-sm">1</span>
        <span class="w-10 h-10 rounded-full bg-cream text-ink-light flex items-center justify-center text-sm hover:bg-rose/10 cursor-pointer">2</span>
        <span class="w-10 h-10 rounded-full bg-cream text-ink-light flex items-center justify-center text-sm hover:bg-rose/10 cursor-pointer">3</span>
      </div>
    </div>
  </section>
</Layout>
