---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ServiceDetail from '../../../components/ServiceDetail.astro';
import { getDictionary } from '../../../i18n';

export async function getStaticPaths() {
  const all = await getCollection('services');
  return all
    .filter((entry) => entry.data.intro?.en !== '' || entry.data.offerings.length > 0)
    .map((entry) => ({
      params: { slug: entry.id.replace(/\.md$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const t = getDictionary('en');
const title = entry.data.title.en;
const description = entry.data.desc.en;
---

<Layout title={`${title} | ${t.meta.siteName}`} description={description} locale="en">
  <article class="max-w-6xl mx-auto px-6 py-16">
    <ServiceDetail locale="en" entry={entry} />
  </article>
</Layout>
