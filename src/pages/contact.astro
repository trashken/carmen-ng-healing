---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Book a session or get in touch with Carmen Ng for holistic healing, energy work, and sound therapy.">
  <section class="py-24 bg-gradient-to-b from-blush to-warm-white min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-rose font-serif text-center text-lg italic mb-2">Get in Touch</p>
      <h1 class="section-title">Book a Session</h1>
      <p class="section-subtitle">I'd love to hear from you. Whether you have questions or are ready to begin your healing journey, reach out below.</p>

      <div class="card max-w-xl mx-auto">
        <form action="/api/contact" method="POST" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="firstName" class="block text-sm font-medium text-ink mb-1.5">First Name</label>
              <input type="text" id="firstName" name="firstName" required
                class="w-full px-4 py-3 rounded-xl border border-rose/20 bg-warm-white text-sm text-ink placeholder:text-ink-light/40 focus:outline-none focus:border-rose focus:ring-1 focus:ring-rose/30" />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-ink mb-1.5">Last Name</label>
              <input type="text" id="lastName" name="lastName" required
                class="w-full px-4 py-3 rounded-xl border border-rose/20 bg-warm-white text-sm text-ink placeholder:text-ink-light/40 focus:outline-none focus:border-rose focus:ring-1 focus:ring-rose/30" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 rounded-xl border border-rose/20 bg-warm-white text-sm text-ink placeholder:text-ink-light/40 focus:outline-none focus:border-rose focus:ring-1 focus:ring-rose/30" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1.5">Message</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full px-4 py-3 rounded-xl border border-rose/20 bg-warm-white text-sm text-ink placeholder:text-ink-light/40 focus:outline-none focus:border-rose focus:ring-1 focus:ring-rose/30 resize-none"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full text-center py-4">Send Message</button>
        </form>
      </div>

      <!-- Alternative contact -->
      <div class="text-center mt-12">
        <!-- <p class="text-ink-light text-sm mb-2">Prefer direct contact?</p>-->
        <p class="text-ink font-serif text-lg">hello@carmennghealing.com</p>
      </div>
    </div>
  </section>
</Layout>
