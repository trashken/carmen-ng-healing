---
import '../styles/global.css';
import { getDictionary, dictionaries, defaultLocale, type Locale, locales } from '../i18n';
import { getEntry } from 'astro:content';

export interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  transparentNav?: boolean;
}

const { title, description, locale = defaultLocale, transparentNav = false } = Astro.props;
const t = getDictionary(locale);
const otherLocales = locales.filter((l) => l !== locale);

// Footer content is driven by the `footer` content collection
// (src/content/footer/main.md), editable from PagesCMS. We resolve
// per-locale strings at render time and fall back to English (or
// the default email) when a field is empty.
const footerData = await getEntry('footer', 'main');
const footerTagline = footerData?.data.tagline
  ? (locale === 'en' ? footerData.data.tagline.en
    : locale === 'jp' ? (footerData.data.tagline.jp || footerData.data.tagline.en)
    : (footerData.data.tagline.zh || footerData.data.tagline.en))
  : '';
const footerEmail = footerData?.data.email || 'hello@carmennghealing.com';
const footerSocialLinks = footerData?.data.social_links || [];
const socialLabel = (link: typeof footerSocialLinks[number]) =>
  locale === 'en' ? (link.label_en || link.label_jp || link.platform)
  : locale === 'jp' ? (link.label_jp || link.label_en || link.platform)
  : (link.label_zh || link.label_en || link.platform);
const footerCopyright = locale === 'en'
  ? (footerData?.data.copyright_en || 'Carmen Ng Healing. All rights reserved.')
  : locale === 'jp'
    ? (footerData?.data.copyright_jp || footerData?.data.copyright_en || 'Carmen Ng Healing. All rights reserved.')
    : (footerData?.data.copyright_zh || footerData?.data.copyright_en || 'Carmen Ng Healing. All rights reserved.');
const footerYear = new Date().getFullYear();

// Smart language switcher: given the target locale and the current URL,
// return the path the switcher should link to.
//
// Rules:
//   1. Strip any existing locale prefix from the current path.
//   2. If the current path is /testimonials or /contact (unlocalized),
//      the switcher goes to that locale's home (/, /jp, or /zh).
//   3. For the root path /, the home for EN is / and the homes for
//      JP/ZH are /jp and /zh respectively.
//   4. For any other localized path, prepend the target locale's prefix.
//      EN is treated as /en/<path> to match the rest of the site's URL
//      scheme (the EN blog lives at /en/blog/... not /blog/...).
//
// Examples (current path -> target EN):
//   /jp/blog/ghibli               -> /en/blog/ghibli
//   /en/blog                      -> /en/blog
//   /jp/blog                      -> /en/blog
//   /jp                           -> /
//   /testimonials                 -> /
//   /contact                      -> /
//
// Examples (current path -> target JP):
//   /en/blog/ghibli               -> /jp/blog/ghibli
//   /jp/blog                      -> /jp/blog
//   /                             -> /jp
//   /testimonials                 -> /jp
function localePathFor(target: Locale, currentPath: string): string {
  // Step 1: strip leading /:en|jp|zh prefix
  const stripped = currentPath.replace(/^\/(en|jp|zh)(?=\/|$)/, '');

  // Step 2: unlocalized routes go to the locale home
  if (stripped === '/testimonials' || stripped === '/contact') {
    return target === defaultLocale ? '/' : `/${target}`;
  }

  // Step 3: root path goes to the locale home
  if (stripped === '' || stripped === '/') {
    return target === defaultLocale ? '/' : `/${target}`;
  }

  // Step 4: any other localized path gets the target locale prefix
  return target === defaultLocale ? `/en${stripped}` : `/${target}${stripped}`;
}

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {t.meta.siteName}</title>
    <meta name="description" content={description || t.meta.defaultDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&family=Noto+Sans+HK:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="overflow-x-hidden">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:bg-coral focus:text-white focus:px-4 focus:py-2 focus:rounded">
      {t.switcher.skipToContent}
    </a>

    <nav
      data-nav
      class:list={[
        'fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b',
        transparentNav
          ? 'bg-transparent border-transparent'
          : 'bg-warm-white/90 backdrop-blur-md border-rose/10',
      ]}
    >
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={locale === defaultLocale ? '/' : `/${locale}`} class="flex items-center gap-3 group">
          <img src="/assets/logo.png" alt={t.meta.siteName} class="w-10 h-10 rounded-full object-cover group-hover:scale-105 transition-transform" />
          <span data-nav-logo class="font-serif text-lg text-ink transition-colors duration-500">Carmen Ng</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a data-nav-link href={locale === defaultLocale ? '/' : `/${locale}`} class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.home}</a>
          <a data-nav-link href={`/${locale}/about`} class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.about}</a>
          <a data-nav-link href={`/${locale}/blog`} class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.blog}</a>
          <a data-nav-link href={`/${locale}/events`} class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.events}</a>
          <a data-nav-link href="/testimonials" class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.testimonials}</a>
          <a data-nav-link href="/contact" class="text-sm text-ink-light hover:text-rose transition-colors">{t.nav.contact}</a>
        </div>
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-1 text-xs">
            {otherLocales.map((l) => (
              <a
                href={localePathFor(l, currentPath)}
                aria-label={`Switch language to ${l}`}
                data-nav-link
                class="px-2 py-1 rounded text-ink-light hover:text-rose hover:bg-rose/5 transition-colors"
              >
                {dictionaries[l].label}
              </a>
            ))}
          </div>
          <a href="/contact" class="btn-primary text-xs px-6 py-2 hidden sm:inline-flex">{t.nav.bookSession}</a>
          <button
            type="button"
            data-menu-toggle
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-md text-ink-light hover:text-rose hover:bg-rose/5 transition-colors"
          >
            <svg data-menu-icon-open xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="18" x2="20" y2="18"></line>
            </svg>
            <svg data-menu-icon-close xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
              <line x1="6" y1="6" x2="18" y2="18"></line>
              <line x1="6" y1="18" x2="18" y2="6"></line>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <div
      id="mobile-menu-backdrop"
      data-menu-backdrop
      class="md:hidden fixed inset-0 z-40 bg-ink/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
      aria-hidden="true"
    ></div>

    <aside
      id="mobile-menu"
      data-menu-panel
      aria-label="Mobile menu"
      class="md:hidden fixed top-0 right-0 z-50 h-full w-72 max-w-[85vw] bg-warm-white border-l border-rose/10 shadow-xl translate-x-full transition-transform duration-300 ease-out flex flex-col"
    >
      <div class="flex items-center justify-between px-6 h-16 border-b border-rose/10">
        <span class="font-serif text-base text-ink">Menu</span>
        <button
          type="button"
          data-menu-close
          aria-label="Close menu"
          class="inline-flex items-center justify-center w-10 h-10 rounded-md text-ink-light hover:text-rose hover:bg-rose/5 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>
      </div>
      <nav class="flex flex-col px-6 py-6 gap-1 text-base">
        <a href={locale === defaultLocale ? '/' : `/${locale}`} class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.home}</a>
        <a href={`/${locale}/about`} class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.about}</a>
        <a href={`/${locale}/blog`} class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.blog}</a>
        <a href={`/${locale}/events`} class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.events}</a>
        <a href="/testimonials" class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.testimonials}</a>
        <a href="/contact" class="py-3 text-ink hover:text-rose transition-colors border-b border-rose/5">{t.nav.contact}</a>
        <a href="/contact" class="btn-primary mt-6 text-center">{t.nav.bookSession}</a>
      </nav>
        <div class="mt-auto px-6 py-6 border-t border-rose/10">
          <p class="text-[10px] uppercase tracking-widest text-ink-light/50 mb-3">{t.switcher.label}</p>
          <div class="flex items-center gap-2 text-xs">
            {otherLocales.map((l) => (
              <a
                href={localePathFor(l, currentPath)}
                aria-label={`Switch language to ${l}`}
                class="px-3 py-1.5 rounded-full border border-rose/20 text-ink-light hover:text-rose hover:border-rose/40 transition-colors"
              >
                {dictionaries[l].label}
              </a>
            ))}
          </div>
      </div>
    </aside>

    <script>
      const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
      const backdrop = document.querySelector<HTMLElement>('[data-menu-backdrop]');
      const closeBtn = document.querySelector<HTMLButtonElement>('[data-menu-close]');
      const iconOpen = document.querySelector<HTMLElement>('[data-menu-icon-open]');
      const iconClose = document.querySelector<HTMLElement>('[data-menu-icon-close]');

      function setOpen(open: boolean) {
        if (!toggle || !panel || !backdrop) return;
        panel.classList.toggle('translate-x-full', !open);
        panel.classList.toggle('translate-x-0', open);
        backdrop.classList.toggle('opacity-0', !open);
        backdrop.classList.toggle('pointer-events-none', !open);
        backdrop.classList.toggle('opacity-100', open);
        backdrop.classList.toggle('pointer-events-auto', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        document.body.classList.toggle('overflow-hidden', open);
        iconOpen?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
      }

      toggle?.addEventListener('click', () => setOpen(toggle.getAttribute('aria-expanded') !== 'true'));
      closeBtn?.addEventListener('click', () => setOpen(false));
      backdrop?.addEventListener('click', () => setOpen(false));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') setOpen(false);
      });
      // Close panel after navigating so SPA-ish transitions don't strand it open
      panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));

      // Nav style swap: transparent at the top of the page, white-on-scroll
      // when there's a hero, dark-aware when scrolling through [data-dark-section]
      // sections (Story / Contact). Mirrors the source repo's Navigation.tsx.
      const nav = document.querySelector<HTMLElement>('[data-nav]');
      const logo = document.querySelector<HTMLElement>('[data-nav-logo]');
      const navLinks = document.querySelectorAll<HTMLElement>('[data-nav-link]');
      const NAV_THRESHOLD = 100;

      function setNavState() {
        if (!nav) return;
        const scrolled = window.scrollY > NAV_THRESHOLD;
        const darkSections = document.querySelectorAll('[data-dark-section]');
        let inDark = false;
        darkSections.forEach((section) => {
          const rect = (section as HTMLElement).getBoundingClientRect();
          if (rect.top < 80 && rect.bottom > 80) inDark = true;
        });
        if (scrolled) {
          if (inDark) {
            nav.className = 'fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b bg-navy-deep/90 backdrop-blur-xl border-white/10';
            logo?.classList.add('text-white');
            logo?.classList.remove('text-ink');
            navLinks.forEach((l) => {
              l.classList.add('text-white/60');
              l.classList.remove('text-ink-light');
            });
          } else {
            nav.className = 'fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b bg-white/80 backdrop-blur-xl border-rose/10 shadow-sm';
            logo?.classList.add('text-ink');
            logo?.classList.remove('text-white');
            navLinks.forEach((l) => {
              l.classList.add('text-ink-light');
              l.classList.remove('text-white/60');
            });
          }
        } else {
          // Above the fold: fully transparent (no border) so the hero
          // gradient is unobstructed.
          nav.className = 'fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b bg-transparent border-transparent';
          logo?.classList.add('text-ink');
          logo?.classList.remove('text-white');
          navLinks.forEach((l) => {
            l.classList.add('text-ink-light');
            l.classList.remove('text-white/60');
          });
        }
      }
      setNavState();
      window.addEventListener('scroll', setNavState, { passive: true });
    </script>

    <main id="main" class="min-h-screen pt-16">
      <slot />
    </main>

    <footer class="bg-navy-dark text-cream mt-24 border-t border-white/10">
      <div class="max-w-6xl mx-auto px-6 py-12">
        {(footerTagline || footerSocialLinks.length > 0) && (
          <div class="text-center mb-10">
            {footerTagline && (
              <p class="text-sm font-light leading-relaxed text-white/70 max-w-xl mx-auto mb-6">
                {footerTagline}
              </p>
            )}
            <a
              href={`mailto:${footerEmail}`}
              class="inline-block text-sm tracking-[0.08em] text-teal-light transition-colors duration-300 hover:text-white mb-4"
            >
              {footerEmail}
            </a>
            {footerSocialLinks.length > 0 && (
              <div class="flex justify-center gap-6 text-xs tracking-[0.08em] text-white/50">
                {footerSocialLinks.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="transition-colors duration-300 hover:text-teal-light"
                  >
                    {socialLabel(link)}
                  </a>
                ))}
              </div>
            )}
          </div>
        )}
        <div class="text-center border-t border-white/10 pt-6">
          <p class="text-xs font-normal tracking-[0.08em] text-white/40 mb-2">
            © {footerYear} {footerCopyright}
          </p>
          <p class="text-xs font-normal tracking-[0.06em] text-white/25">
            {t.disclaimer}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

