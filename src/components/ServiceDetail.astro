---
import { type CollectionEntry } from 'astro:content';
import { type Locale } from '../i18n';
import { renderInlineMarkdown } from '../lib/markdown';

export interface Props {
  locale: Locale;
  entry: CollectionEntry<'services'>;
}

const { locale, entry } = Astro.props;
const d = entry.data;

const pickL10n = (s?: { en: string; jp: string; zh?: string }) => {
  if (!s) return '';
  if (locale === 'en') return s.en;
  if (locale === 'jp') return s.jp;
  return s.zh || s.jp;
};

const title = pickL10n(d.title) || d.title.en;
const subtitle = (d.subtitle && pickL10n(d.subtitle)) || (d.subtitle?.en ?? '') || pickL10n(d.desc) || d.desc.en;
const tagline = pickL10n(d.tagline);
const intro = pickL10n(d.intro);
const bodyMd = pickL10n(d.serviceBody);
const bodyHtml = renderInlineMarkdown(bodyMd);
const isFallback =
  (d.tagline?.jp === '' || d.tagline?.jp == null) && d.tagline?.en !== '';

const colorClasses: Record<'rose' | 'lavender' | 'sky' | 'peach', { bg: string; text: string; ring: string }> = {
  rose:     { bg: 'bg-rose/10',     text: 'text-rose',     ring: 'ring-rose/20' },
  lavender: { bg: 'bg-lavender/10', text: 'text-lavender', ring: 'ring-lavender/20' },
  sky:      { bg: 'bg-sky/10',      text: 'text-sky',      ring: 'ring-sky/20' },
  peach:    { bg: 'bg-peach/10',    text: 'text-peach',    ring: 'ring-peach/20' },
};
const cc = colorClasses[d.color];

const contactPath = locale === 'en' ? '/contact' : `/${locale}/contact`;
const servicesPath = locale === 'en' ? '/en/services' : `/${locale}/services`;

const copy = {
  en: {
    overview: 'Overview',
    offerings: 'Session options & pricing',
    duration: 'Duration',
    fee: 'Fee',
    bookSession: 'Book a session',
    contactForPrice: 'Contact for pricing',
    fallbackNote: 'The full Japanese / Chinese translation of this service is in progress. Showing the English version for now.',
    backToServices: '← All services',
    testimonialsHeading: 'Client stories',
  },
  jp: {
    overview: '概要',
    offerings: 'セッション内容・料金',
    duration: '所要時間',
    fee: '料金',
    bookSession: 'ご予約・お問い合わせ',
    contactForPrice: '料金はお問い合わせください',
    fallbackNote: 'このページの一部は英語版を表示しています。日本語訳は順次整えていきます。',
    backToServices: '← サービス一覧',
    testimonialsHeading: 'ご感想',
  },
  zh: {
    overview: '療程簡介',
    offerings: '療程選項及費用',
    duration: '所需時間',
    fee: '費用',
    bookSession: '預約 / 查詢',
    contactForPrice: '歡迎查詢收費',
    fallbackNote: '此頁部分正進行中文翻譯，現階段先以英文版本顯示。',
    backToServices: '← 返回服務總覽',
    testimonialsHeading: '客戶分享',
  },
}[locale];
---

<a href={servicesPath} class="block text-sm text-rose hover:underline mb-6">{copy.backToServices}</a>

<header class="mb-12 max-w-3xl">
  {/* <p class={`text-sm font-serif mb-3 ${cc.text} tracking-widest uppercase`}>{subtitle}</p>*/}
  <h1 class="font-serif text-4xl md:text-5xl font-bold text-ink mb-4 leading-tight">{title}</h1>
  {tagline && <p class="text-lg md:text-xl text-ink-light font-serif">{tagline}</p>}
</header>

{isFallback && (
  <div class="mb-8 px-4 py-3 rounded-md bg-blush/50 border border-rose/20 text-sm text-ink-light">
    {copy.fallbackNote}
  </div>
)}

{intro && (
  <section class="mb-12 max-w-3xl">
    <h2 class={`section-title text-left md:text-left`}>{copy.overview}</h2>
    <p class="text-ink-light leading-relaxed whitespace-pre-line">{intro}</p>
  </section>
)}

{bodyHtml && (
  <section
    class="service-body mb-12 max-w-3xl text-ink-light leading-relaxed
           [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:text-ink [&_h2]:mt-10 [&_h2]:mb-4
           [&_h3]:font-serif [&_h3]:text-xl [&_h3]:text-ink [&_h3]:mt-8 [&_h3]:mb-3
           [&_p]:mb-4 [&_p]:whitespace-pre-line
           [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:space-y-1
           [&_li]:text-ink-light"
    set:html={bodyHtml}
  />
)}

{(d.testimonial_1 || d.testimonial_2 || d.testimonial_3) && (
  <section class="mb-12 max-w-3xl">
    <h2 class="font-serif text-2xl text-ink mb-6">{copy.testimonialsHeading}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[d.testimonial_1, d.testimonial_2, d.testimonial_3]
        .filter((t) => t && t.trim())
        .map((t) => (
          <blockquote class="relative bg-white border border-rose/15 rounded-2xl p-6 shadow-sm">
            <span class="absolute left-4 top-3 font-serif text-4xl leading-none text-teal/20">
              &ldquo;
            </span>
            <p class="relative z-10 pt-4 text-sm font-light leading-relaxed text-ink-light whitespace-pre-line">
              {t}
            </p>
          </blockquote>
        ))}
    </div>
  </section>
)}

{d.offerings && d.offerings.length > 0 && (
  <section class="mb-12">
    <h2 class="font-serif text-2xl text-ink mb-6">{copy.offerings}</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {d.offerings.map((o) => {
        const oTitle = o.title ? (pickL10n(o.title) || o.title.en) : '';
        const oDesc = pickL10n(o.desc);
        const oBullets = (locale === 'jp' ? o.bullets?.jp : (locale === 'zh' ? (o.bullets?.zh || o.bullets?.jp || []) : (o.bullets?.en || []))) ?? [];
        const oDuration = pickL10n(o.duration);
        // Per-locale currency prefix inferred from the locale.
        const oCurrency = locale === 'jp' ? '¥' : locale === 'zh' ? 'HK$' : 'US$';
        const oPrice = (locale === 'jp' ? o.price?.jp : (locale === 'zh' ? (o.price?.zh ?? o.price?.jp ?? 0) : (o.price?.en ?? 0))) ?? 0;
        return (
          <div class={`card ring-1 ${cc.ring} flex flex-col`}>
            <h3 class="font-serif text-lg text-ink mb-2">{oTitle}</h3>
            {oDesc && <p class="text-sm text-ink-light leading-relaxed mb-4 whitespace-pre-line">{oDesc}</p>}
            {oBullets && oBullets.length > 0 && (
              <ul class="text-xs text-ink-light space-y-1.5 mb-4 flex-1">
                {oBullets.map((b) => (
                  <li class="flex gap-2">
                    <span class={`${cc.text} flex-shrink-0`}>·</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-auto pt-4 border-t border-rose/10 text-sm space-y-1.5">
              {oDuration && (
                <div class="flex justify-between">
                  <span class="text-ink-light/70">{copy.duration}</span>
                  <span class="text-ink font-medium">{oDuration}</span>
                </div>
              )}
              <div class="flex justify-between items-baseline">
                <span class="text-ink-light/70">{copy.fee}</span>
                {oPrice > 0 ? (
                  <span class="text-ink font-medium">{oCurrency}{oPrice.toLocaleString(locale === 'en' ? 'en-US' : locale === 'jp' ? 'ja-JP' : 'zh-HK')}</span>
                ) : (
                  <span class="text-ink-light italic text-xs">{copy.contactForPrice}</span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>
)}

<div class="text-center my-12">
  <a href={contactPath} class="btn-primary text-base px-10 py-4">{copy.bookSession}</a>
</div>
