<script>
  // Info section tabs (News | Blogs). Pure client-side toggle.
  function activate(name: string) {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-info-tab]');
    tabs.forEach((tab) => {
      const isActive = tab.getAttribute('data-info-tab') === name;
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      tab.className = isActive
        ? 'info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-teal text-white transition-all duration-300'
        : 'info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-white text-navy-text/60 hover:text-navy-text transition-all duration-300';
    });
    document.querySelectorAll<HTMLElement>('[data-info-panel]').forEach((panel) => {
      panel.classList.toggle('hidden', panel.getAttribute('data-info-panel') !== name);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('[data-info-tab]').forEach((tab) => {
    tab.addEventListener('click', () => {
      const name = tab.getAttribute('data-info-tab');
      if (name) activate(name);
    });
  });
</script>
