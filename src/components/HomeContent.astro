---
import { getCollection, getEntry } from 'astro:content';
import { type Locale } from '../i18n';
import EventTime from './EventTime.astro';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = (await import('../i18n')).getDictionary(locale);
const home = t.home;

// Per-locale lookup helper. EN uses the English value; JP uses the
// Japanese (falling back to EN); ZH uses Chinese (falling back to JP).
const pickL10n = (s: { en: string; jp: string; zh?: string }) =>
  locale === 'en' ? s.en : (locale === 'jp' ? s.jp : (s.zh || s.jp));

// Hero block: fetched from the single-entry `hero` collection. Per-locale
// overrides fall back to the i18n defaults when empty. The getEntry
// return is typed as `undefined` so we guard with `??` when reading
// each field — a missing entry is treated the same as an empty one.
const heroEntry = await getEntry('hero', 'main');
const heroData = heroEntry?.data;
const heroTitle = pickL10n(heroData?.title ?? { en: '', jp: '' });
const heroTagline = pickL10n(heroData?.tagline) || home.hero.tagline;
const heroDescription = (() => {
  if (!heroData?.description) return home.hero.description;
  if (locale === 'en') return heroData.description.en || home.hero.description;
  if (locale === 'jp') return heroData.description.jp || heroData.description.en || home.hero.description;
  return heroData.description.zh || heroData.description.en || home.hero.description;
})();
const heroCtaPrimary = pickL10n(heroData?.cta_primary) || home.bookSession;
const heroCtaSecondary = pickL10n(heroData?.cta_secondary) || home.exploreServices;

const allServices = await getCollection('services');
const services = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    slug: entry.id.replace(/\.md$/, ''),
    icon: entry.data.icon,
    image: entry.data.image || '',
    title: pickL10n(entry.data.title),
    subtitle: entry.data.subtitle ? pickL10n(entry.data.subtitle) : (pickL10n(entry.data.desc) || entry.data.desc.en),
    description: pickL10n(entry.data.desc),
  }));

// Latest 3 blog posts for the Info section.
const allPosts = await getCollection('blog');
const topPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const postTitle = (p: typeof topPosts[number]) => pickL10n(p.data.title);
const formatDate = (iso: Date) => {
  const y = iso.getFullYear();
  const m = String(iso.getMonth() + 1).padStart(2, '0');
  const d = String(iso.getDate()).padStart(2, '0');
  return locale === 'en'
    ? iso.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
    : `${y}.${m}.${d}`;
};

// Upcoming events for the Info section.
const allEvents = await getCollection('events');
const now = Date.now();
// The date field is a YYYY-MM-DD or YYYY-MM-DDTHH:mm string. The
// `timezone` field tells the page which TZ the wall-clock is in;
// we don't do any TZ conversion — the date string is shown as-is.
const eventReferenceDate = (e: typeof allEvents[number]) => e.data.endDate ?? e.data.date;
const formatEventDate = (s: string) =>
  new Date(s).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' });
const hasTime = (s: string) => /T\d{2}:\d{2}/.test(s);
const upcomingEvents = allEvents
  .filter((e) => new Date(eventReferenceDate(e)).getTime() >= now)
  .sort((a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf())
  .slice(0, 3);
const eventTitle = (e: typeof upcomingEvents[number]) => pickL10n(e.data.title);

// Story section data: pulled from the about collection.
const about = await getEntry('about', 'main');
const storyParas = (() => {
  if (!about) return [];
  // Pick the per-locale body. EN uses the EN field; JP and ZH prefer
  // their own, falling back to JP for ZH if missing.
  const body = locale === 'en'
    ? (about.data.body_en || about.data.body_jp || '')
    : (about.data.body_zh || about.data.body_jp || '');
  return body.split(/\n\s*\n/).slice(0, 3);
})();
const certs = (about?.data.certifications || []).flatMap((c) => {
  // EN uses EN items/school; JP and ZH use the JP items/school (the
  // same list — they're school names, not localizable text).
  const items = locale === 'en' ? (c.items_en || []) : (c.items_jp || []);
  const school = locale === 'en' ? c.school_en : c.school_jp;
  return items.slice(0, 1).map(() => school);
});
const flatCerts = Array.from(new Set(certs)).slice(0, 6);

// Static testimonials fallback. The full 94 live in the testimonials
// collection; the homepage just shows 3 highlighted quotes — different
// ones per locale.
const testimonials = locale === 'jp' ? [
  { name: 'Kao', quote: '心も体も軽くなり、自分の進みたい方向もはっきりして、とても安心しました。' },
  { name: 'もん', quote: '実際の誘導以外の説明やアフターケアを絵や文字で示してくださり、確認しやすかったです。' },
  { name: 'おゆ', quote: '感謝と愛をたくさん感じることができる時間は改めて幸せだなあと思いました。' },
] : locale === 'zh' ? [
  { name: 'Christine', quote: '我 75 歲，呢幾年身體一路有好幾處唔舒服……做完 RAAH 療程後，多年來第一次瞓得咁好。' },
  { name: 'M', quote: '整個過程非常舒適和放鬆。療程後我感到身心被淨化，感官也變得敏銳。' },
  { name: 'Kylie', quote: "Carmen's 引導清晰、溫柔，讓我更深地連結自己的本質。" },
] : [
  { name: 'Monika', quote: 'Thank you very much Carmen for sharing your gifts and light! I experienced the healing session twice and it was absolutely unique. Light codes transmissions were so powerful and tangible.' },
  { name: 'Chun Ling', quote: "My right shoulder is improving already. The movement range is bigger and I can do a yoga pose which I couldn't do before today. And I'm in such a brightened mood today." },
  { name: 'Cary', quote: 'It was an amazing experience! The whole process was very relaxing and enlightening. After the session, I felt like my mind and body has been cleansed and my senses heightened.' },
];

// URL paths. The `/testimonials` and `/contact` routes are
// locale-unaware; everything else is prefixed with the locale.
const blogIndexPath = locale === 'en' ? '/en/blog' : `/${locale}/blog`;
const eventsIndexPath = locale === 'en' ? '/en/events' : `/${locale}/events`;
const aboutPath = locale === 'en' ? '/en/about' : `/${locale}/about`;
const contactPath = locale === 'en' ? '/contact' : `/${locale}/contact`;
---

<!-- ============================== HERO ============================== -->
<section
  id="hero"
  data-dark-section
  class="relative min-h-screen w-full overflow-hidden"
  style="background: linear-gradient(-90deg, #004aad 0%, #1871bc 30%, #39a7d0 60%, #48bfd9 85%, #5de0e6 100%);"
>
  <!-- Floating clouds -->
  <img
    src="/assets/BigCloud.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute left-[5%] top-[8%] w-[540px] lg:w-[660px] animate-[cloud-drift_18s_ease-in-out_infinite]"
  />
  <img
    src="/assets/SmallCloud.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute right-[8%] top-[15%] w-[320px] lg:w-[440px] animate-[cloud-drift_18s_ease-in-out_infinite]"
    style="animation-delay: -9s; animation-direction: reverse;"
  />

  <div class="mx-auto flex min-h-screen max-w-[2160px] flex-col items-center px-3 pt-24 md:flex-row md:items-center md:justify-between md:px-6 md:pt-0 lg:px-8">
    <!-- Left: Mount Fuji + cherry blossom + sun disc -->
    <div class="relative flex w-full justify-center md:w-[90%] md:justify-start">
      <img
        src="/assets/MtFuji.png"
        alt=""
        role="presentation"
        class="relative z-10 w-[2160px] md:w-[2160px] lg:w-[2160px]"
      />
      <img
        src="/assets/SakuraBranch.png"
        alt=""
        role="presentation"
        class="pointer-events-none absolute -bottom-50 -left-4 z-20 w-[300px] md:-left-8 md:w-[440px] lg:w-[720px]"
      />
      <div
        class="relative right-[15%] top-[5%] h-[120px] w-[120px] rounded-full md:right-[20%] md:h-[180px] md:w-[180px]"
      >
        <img
          src="/assets/MoonSun.png"
          alt=""
          role="presentation"
          class="pointer-events-none relative z-5 w-[3600px] md:-left-8 md:w-[5220px] lg:w-[6360px]"
        />
      </div>
    </div>

    <!-- Right: Text content -->
    <div class="relative z-20 mt-6 w-full text-center md:mt-0 md:w-[50%] md:text-left">
      <h1 class="font-serif text-4xl font-normal uppercase tracking-[0.15em] text-white md:text-5xl lg:text-6xl">
        {heroTitle}
      </h1>
      {heroTagline && (
        <p class="mt-4 font-serif text-sm font-normal uppercase tracking-[0.25em] text-white md:text-base">
          {heroTagline}
        </p>
      )}
      <p class="mx-auto mt-6 max-w-[380px] text-sm font-light leading-relaxed text-white/70 md:mx-0">
        {heroDescription}
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row md:items-start">
        <a href={contactPath} class="inline-block rounded-full bg-coral px-8 py-3 text-sm font-normal tracking-[0.1em] text-white shadow-lg shadow-coral/25 transition-all duration-300 hover:bg-coral-dark hover:shadow-xl hover:shadow-coral/30">
          {heroCtaPrimary}
        </a>
        <a href="#services" class="inline-block rounded-full border bg-[#f1f4f6] border-navy-text/20 px-8 py-3 text-sm font-normal tracking-[0.1em] text-navy-text transition-all duration-300 hover:border-teal hover:text-teal">
          {heroCtaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ============================== INFO (News / Blogs) ============================== -->
<section
  id="info"
  class="relative w-full bg-gray-section py-20 md:py-28"
>
  <div class="mx-auto flex max-w-[1200px] flex-col gap-12 px-6 md:flex-row md:gap-16 md:px-12 lg:px-8">
    <!-- Left: heading + torii gate art -->
    <div class="relative md:w-[40%]">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.info.title}
      </h2>
      <p class="mt-2 font-sans text-base tracking-[0.1em] text-navy-text/50">
        {home.info.sub}
      </p>
      <div class="relative mt-6">
        <img
          src="/assets/DragonCloud.png"
          alt=""
          role="presentation"
          class="w-[220px] md:w-[280px] animate-[cloud-drift_18s_ease-in-out_infinite]"
        />        
        <img
          src="/assets/ShrineGate.png"
          alt=""
          role="presentation"
          class="w-[220px] md:w-[280px]"
        />        
        <img
          src="/assets/cloud-formation.png"
          alt=""
          role="presentation"
          class="pointer-events-none absolute -right-4 top-0 w-[80px] opacity-40 animate-[cloud-drift_18s_ease-in-out_infinite]"
        />
      </div>
    </div>

    <!-- Right: tabs (News | Blogs) -->
    <div class="md:w-[60%]">
      <div class="mb-8 flex gap-0">
        <button
          type="button"
          data-info-tab="news"
          aria-selected="true"
          class="info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-teal text-white transition-all duration-300"
        >
          {home.info.tabNews}
        </button>
        <button
          type="button"
          data-info-tab="blogs"
          aria-selected="false"
          class="info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-white text-navy-text/60 hover:text-navy-text transition-all duration-300"
        >
          {home.info.tabBlogs}
        </button>
      </div>

      <!-- News panel (events) -->
      <div data-info-panel="news" class="space-y-0">
        {upcomingEvents.length === 0 ? (
          <p class="text-sm text-navy-text/60 italic px-6 py-5">No upcoming events.</p>
        ) : (
          upcomingEvents.map((event) => (
            <a
              href={eventsIndexPath}
              class="group block border-b border-navy-text/10 bg-white px-6 py-5 transition-all duration-300 hover:bg-sky-light/50"
            >
              <p class="mb-1 text-xs tracking-[0.08em] text-navy-text/40">
                {formatEventDate(event.data.date)}
                {hasTime(event.data.date) && (
                  <>
                    {' · '}
                    <EventTime
                      start={event.data.date}
                      end={event.data.endDate}
                      timezone={event.data.timezone}
                      twelvesHours={true}
                    />
                  </>
                )}
              </p>
              <p class="text-sm font-normal leading-relaxed text-navy-text transition-colors duration-300 group-hover:text-teal">
                {eventTitle(event)}
              </p>
            </a>
          ))
        )}
        <div class="mt-4 text-right">
          <a
            href={eventsIndexPath}
            class="inline-block text-sm tracking-[0.08em] text-navy-text/50 transition-colors duration-300 hover:text-teal"
          >
            {home.info.moreNews}
          </a>
        </div>
      </div>

      <!-- Blogs panel -->
      <div data-info-panel="blogs" class="space-y-0 hidden">
        {topPosts.map((post) => (
          <a
            href={`${blogIndexPath}/${post.data.slug}`}
            class="group block border-b border-navy-text/10 bg-white px-6 py-5 transition-all duration-300 hover:bg-sky-light/50"
          >
            <p class="mb-1 text-xs tracking-[0.08em] text-navy-text/40">
              {formatDate(post.data.date)}
            </p>
            <p class="text-sm font-normal leading-relaxed text-navy-text transition-colors duration-300 group-hover:text-teal">
              {postTitle(post)}
            </p>
          </a>
        ))}
        <div class="mt-4 text-right">
          <a
            href={blogIndexPath}
            class="inline-block text-sm tracking-[0.08em] text-navy-text/50 transition-colors duration-300 hover:text-teal"
          >
            {home.info.moreBlogs}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================== SERVICES ============================== -->
<section
  id="services"
  class="relative w-full overflow-hidden bg-white py-20 md:py-28"
>
  {/* Background PetalSwirl: covers the entire section, low opacity, */}
  {/* centered. Pointer events disabled so it never blocks clicks. */}
  <img
    src="/assets/PetalSwirl.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute inset-0 w-full h-full object-cover opacity-15"
  />
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-12 md:mb-16">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.services.title}
      </h2>
      {/* <p class="mt-3 max-w-[400px] text-sm font-light leading-relaxed text-navy-text/60">
        {home.services.subtitle}
      </p>*/}
    </div>

    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 md:gap-8 lg:gap-10">
      {services.map((s) => {
        const detailHref = `/${locale}/services/${s.slug}`;
        return s.image ? (
          <a href={detailHref} class="group cursor-pointer text-center">
            <div class="relative mx-auto mb-4 aspect-square w-full max-w-[180px] overflow-hidden rounded-full md:max-w-[200px] bg-gradient-to-br from-sky-light to-cream">
              <img
                src={s.image}
                alt={s.title}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 rounded-full bg-teal/0 transition-all duration-500 group-hover:bg-teal/20"></div>
            </div>
            <h3 class="font-serif text-sm font-normal uppercase tracking-[0.1em] text-navy-text transition-colors duration-300 group-hover:text-teal md:text-base">
              {s.title}
            </h3>
            {/* <p class="mt-1 text-xs tracking-[0.05em] text-navy-text/40">
              {s.subtitle}
            </p>*/}
          </a>
        ) : (
          <a href={detailHref} class="card group block hover:-translate-y-1 text-left">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-12 h-12 rounded-xl bg-sky-light/40 flex items-center justify-center text-2xl text-teal/70 transition-transform duration-300 group-hover:scale-110">
                {s.icon}
              </div>
              <h3 class="font-serif text-xl text-navy-text leading-snug group-hover:text-teal transition-colors duration-300">
                {s.title}
              </h3>
            </div>
            {/*<p class="text-[11px] text-rose tracking-wider uppercase mb-2">
              {s.subtitle}
            </p>*/}
            {s.description && (
              <p class="text-sm text-navy-text/80 leading-relaxed">
                {s.description}
              </p>
            )}
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================== TESTIMONIALS ============================== -->
<section
  id="testimonials"
  class="relative w-full overflow-hidden bg-[#d2e7ec] py-20 md:py-28"
>
  <div class="absolute -top-1 left-0 w-full rotate-180">
    <img
      src="/assets/ocean-waves.png"
      alt=""
      role="presentation"
      class="pointer-events-none w-full opacity-10"
      style="mask-image: linear-gradient(to bottom, black 0%, transparent 80%); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%);"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.testimonials.title}
      </h2>
      <!-- <p class="mt-2 font-sans text-sm tracking-[0.15em] text-navy-text/40">
        {home.testimonials.sub}
      </p>-->
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {testimonials.map((t) => (
        <div class="relative bg-white px-8 py-10">
          <span class="absolute left-6 top-6 font-serif text-5xl leading-none text-teal/20">
            &ldquo;
          </span>
          <p class="relative z-10 mb-6 pt-6 text-sm font-light leading-relaxed text-navy-text/80">
            {t.quote}
          </p>
          <p class="text-xs font-normal tracking-[0.15em] text-teal">
            — {t.name}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="/testimonials"
        class="inline-block text-sm tracking-[0.08em] text-navy-text/50 transition-colors duration-300 hover:text-teal"
      >
        Read all stories →
      </a>
    </div>
  </div>

  <div class="absolute -bottom-1 left-0 w-full">
    <img
      src="/assets/ocean-waves.png"
      alt=""
      role="presentation"
      class="pointer-events-none w-full opacity-15"
      style="mask-image: linear-gradient(to top, black 0%, transparent 80%); -webkit-mask-image: linear-gradient(to top, black 0%, transparent 80%);"
    />
  </div>
</section>

<!-- ============================== STORY (dark) ============================== -->
<section
  id="story"
  data-dark-section
  class="relative w-full overflow-hidden bg-navy-deep py-20 md:py-28"
>
  <img
    src="/assets/cloud-formation.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute -left-10 top-[10%] w-[150px] opacity-20 animate-[cloud-drift_18s_ease-in-out_infinite]"
  />

  <div class="relative z-10 mx-auto flex max-w-[1200px] flex-col items-center gap-12 px-6 md:flex-row md:gap-16 md:px-12 lg:px-8">
    <div class="w-full md:w-[45%]">
      <img
        src="/assets/story-mountains.png"
        alt=""
        role="presentation"
        class="w-full max-w-[400px]"
      />
    </div>

    <div class="w-full md:w-[55%]">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-white md:text-4xl">
        {home.story.title}
      </h2>
      <p class="mt-2 text-sm tracking-[0.1em] text-white/40">
        {home.story.sub}
      </p>

      <div class="mt-8 space-y-5">
        {storyParas.map((p) => (
          <p class="text-sm font-light leading-relaxed text-white/80">
            {p}
          </p>
        ))}
      </div>

      <p class="mt-8 text-[10px] uppercase tracking-[0.2em] text-white/40">
        {home.story.certEyebrow}
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        {flatCerts.map((cert) => (
          <span class="rounded-full border border-white/20 px-4 py-1.5 text-xs tracking-[0.05em] text-white/60">
            {cert}
          </span>
        ))}
      </div>

      <a
        href={aboutPath}
        class="mt-8 inline-block text-sm tracking-[0.08em] text-teal-light transition-colors duration-300 hover:text-white"
      >
        Read more →
      </a>
    </div>
  </div>
</section>


<!-- ============================== CONTACT (dark) ============================== -->
<section
  id="contact"
  data-dark-section
  class="relative w-full overflow-hidden bg-navy-deep py-20 md:py-28"
>
  <div class="absolute bottom-0 left-0 w-[280px] overflow-hidden lg:w-[380px]">
    <img
      src="/assets/lotus-flowers.png"
      alt=""
      role="presentation"
      class="pointer-events-none w-full"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-16 md:mb-20">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-white md:text-4xl">
        {home.contact.title}
      </h2>
      <p class="mt-2 text-sm tracking-[0.1em] text-white/40">
        {home.contact.sub}
      </p>

      <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-16">
        <div>
          <p class="mb-6 text-sm font-light leading-relaxed text-white/70">
            All sessions are held online via Zoom. I welcome clients from all over the world. Feel free to reach out with any questions or to book your session.
          </p>
          <div class="space-y-3">
            <a
              href={`mailto:${home.contact.email}`}
              class="block text-sm tracking-[0.06em] text-teal-light transition-colors duration-300 hover:text-white"
            >
              {home.contact.email}
            </a>
            <div class="flex gap-6 pt-2 text-xs tracking-[0.06em] text-white/50">
              <a href="https://instagram.com/carmennghealing" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-teal-light">Instagram</a>
              <a href="https://youtube.com/@CarmenNgHealing" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-teal-light">YouTube</a>
