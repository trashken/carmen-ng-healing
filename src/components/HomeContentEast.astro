---
import { getCollection, getEntry } from 'astro:content';

export interface Props {
  locale: 'jp' | 'zh';
}

const { locale } = Astro.props;
const t = (await import('../i18n')).getDictionary(locale);
const home = t.home;

// Hero block: fetched from the single-entry `hero` collection. Per-locale
// overrides fall back to the i18n defaults when empty.
const heroEntry = await getEntry('hero', 'main');
const heroTitle = locale === 'jp'
  ? (heroEntry.data.title.jp || heroEntry.data.title.en)
  : (heroEntry.data.title.zh || heroEntry.data.title.en);
const heroKana = heroEntry.data.title_kana || (locale === 'jp' ? 'カーメン' : '');
const heroWelcome = heroEntry.data.welcome || home.hero.welcome;
const heroTagline = heroEntry.data.tagline || home.hero.tagline;
const heroDescription = heroEntry.data.description || home.hero.description;
const heroCtaPrimary = heroEntry.data.cta_primary || home.hero.bookSession;
const heroCtaSecondary = heroEntry.data.cta_secondary || home.hero.exploreServices;

const allServices = await getCollection('services');
const pickL10n = (s: { en: string; jp: string; zh?: string }) =>
  locale === 'jp' ? s.jp : (s.zh || s.jp);
const services = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    slug: entry.id.replace(/\.md$/, ''),
    icon: entry.data.icon,
    image: entry.data.image || '',
    title: pickL10n(entry.data.title),
    subtitle: entry.data.subtitle ? pickL10n(entry.data.subtitle) : (pickL10n(entry.data.desc) || entry.data.desc.en),
    description: pickL10n(entry.data.desc),
  }));

const allPosts = await getCollection('blog');
const topPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const postTitle = (p: typeof topPosts[number]) =>
  locale === 'jp' ? p.data.title.jp : (p.data.title.zh || p.data.title.jp);
const formatDate = (iso: Date) => {
  const y = iso.getFullYear();
  const m = String(iso.getMonth() + 1).padStart(2, '0');
  const d = String(iso.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
};

const allEvents = await getCollection('events');
const now = Date.now();
// The date field is a YYYY-MM-DD or YYYY-MM-DDTHH:mm string. The
// `timezone` field tells the page which TZ the wall-clock is in;
// we don't do any TZ conversion — the date string is shown as-is.
const eventReferenceDate = (e: typeof allEvents[number]) => e.data.endDate ?? e.data.date;
const formatEventDate = (s: string) =>
  new Date(s).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' });
const upcomingEvents = allEvents
  .filter((e) => new Date(eventReferenceDate(e)).getTime() >= now)
  .sort((a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf())
  .slice(0, 3);
const eventTitle = (e: typeof upcomingEvents[number]) =>
  locale === 'jp' ? e.data.title.jp : (e.data.title.zh || e.data.title.jp);

const about = await getEntry('about', 'main');
const storyParas = (() => {
  if (!about) return [];
  const body = locale === 'jp' ? about.data.body_jp : (about.data.body_zh || about.data.body_jp);
  return body.split(/\n\s*\n/).slice(0, 3);
})();
const certs = (about?.data.certifications || []).flatMap((c) =>
  (c.items_jp || []).slice(0, 1).map(() => c.school_jp)
);
const flatCerts = Array.from(new Set(certs)).slice(0, 6);

const allFaqs = await getCollection('faqs');
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);
const faqQ = (f: typeof sortedFaqs[number]) =>
  locale === 'jp' ? (f.data.question.jp || f.data.question.en) : (f.data.question.zh || f.data.question.en);
const faqA = (f: typeof sortedFaqs[number]) =>
  locale === 'jp' ? (f.data.answer.jp || f.data.answer.en) : (f.data.answer.zh || f.data.answer.en);

const testimonials = locale === 'jp' ? [
  { name: 'Kao', quote: '心も体も軽くなり、自分の進みたい方向もはっきりして、とても安心しました。' },
  { name: 'もん', quote: '実際の誘導以外の説明やアフターケアを絵や文字で示してくださり、確認しやすかったです。' },
  { name: 'おゆ', quote: '感謝と愛をたくさん感じることができる時間は改めて幸せだなあと思いました。' },
] : [
  { name: 'Christine', quote: '我 75 歲，呢幾年身體一路有好幾處唔舒服……做完 RAAH 療程後，多年來第一次瞓得咁好。' },
  { name: 'M', quote: '整個過程非常舒適和放鬆。療程後我感到身心被淨化，感官也變得敏銳。' },
  { name: 'Kylie', quote: "Carmen's 引導清晰、溫柔，讓我更深地連結自己的本質。" },
];

const blogIndexPath = `/${locale}/blog`;
const eventsIndexPath = `/${locale}/events`;
const aboutPath = `/${locale}/about`;
const contactPath = `/${locale}/contact`;
---

<!-- ============================== HERO ============================== -->
<section
  id="hero"
  data-dark-section
  class="relative min-h-screen w-full overflow-hidden"
  style="background: linear-gradient(180deg, #7EC8E3 0%, #B8DCE8 30%, #D4EBF3 60%, #E8F4F8 85%, #EDF1F5 100%);"
>
  <img
    src="/assets/cloud-formation.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute left-[5%] top-[8%] w-[180px] opacity-70 lg:w-[220px] animate-[cloud-drift_18s_ease-in-out_infinite]"
  />
  <img
    src="/assets/cloud-formation.png"
    alt=""
    role="presentation"
    class="pointer-events-none absolute right-[8%] top-[15%] w-[140px] opacity-60 lg:w-[180px] animate-[cloud-drift_18s_ease-in-out_infinite]"
    style="animation-delay: -9s; animation-direction: reverse;"
  />

  <div class="mx-auto flex min-h-screen max-w-[1200px] flex-col items-center px-6 pt-24 md:flex-row md:items-center md:justify-between md:px-12 md:pt-0 lg:px-8">
    <div class="relative flex w-full justify-center md:w-[50%] md:justify-start">
      <img
        src="/assets/fuji.png"
        alt=""
        role="presentation"
        class="relative z-10 w-[280px] md:w-[400px] lg:w-[480px]"
      />
      <img
        src="/assets/cherry-blossom.png"
        alt=""
        role="presentation"
        class="pointer-events-none absolute -bottom-8 -left-4 z-20 w-[200px] md:-left-8 md:w-[280px] lg:w-[340px]"
      />
      <div class="absolute right-[15%] top-[5%] h-[60px] w-[60px] rounded-full bg-gradient-to-br from-amber-200 to-amber-400 opacity-60 blur-[1px] md:right-[20%] md:h-[80px] md:h-[80px] md:w-[80px]"></div>
    </div>

    <div class="relative z-20 mt-6 w-full text-center md:mt-0 md:w-[50%] md:text-left">
      <h1 class="font-serif text-4xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-5xl lg:text-6xl">
        {heroTitle}
      </h1>
      {heroKana && (
        <p class="mt-2 font-sans text-lg font-normal tracking-[0.2em] text-navy-text/70 md:text-xl">
          {heroKana}
        </p>
      )}
      {heroWelcome && (
        <p class="mt-2 font-sans text-sm font-normal tracking-[0.2em] text-navy-text/60 md:text-base">
          {heroWelcome}
        </p>
      )}
      {heroTagline && (
        <p class="mt-4 font-serif text-sm font-normal uppercase tracking-[0.25em] text-teal md:text-base">
          {heroTagline}
        </p>
      )}
      <p class="mx-auto mt-6 max-w-[380px] text-sm font-light leading-relaxed text-navy-text/70 md:mx-0">
        {heroDescription}
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row md:items-start">
        <a href={contactPath} class="inline-block rounded-full bg-coral px-8 py-3 text-sm font-normal tracking-[0.1em] text-white shadow-lg shadow-coral/25 transition-all duration-300 hover:bg-coral-dark hover:shadow-xl hover:shadow-coral/30">
          {heroCtaPrimary}
        </a>
        <a href="#services" class="inline-block rounded-full border border-navy-text/20 px-8 py-3 text-sm font-normal tracking-[0.1em] text-navy-text transition-all duration-300 hover:border-teal hover:text-teal">
          {heroCtaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ============================== INFO ============================== -->
<section
  id="info"
  class="relative w-full bg-gray-section py-20 md:py-28"
>
  <div class="mx-auto flex max-w-[1200px] flex-col gap-12 px-6 md:flex-row md:gap-16 md:px-12 lg:px-8">
    <div class="relative md:w-[40%]">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.info.title}
      </h2>
      <p class="mt-2 font-sans text-base tracking-[0.1em] text-navy-text/50">
        {home.info.sub}
      </p>
      <div class="relative mt-6">
        <img src="/assets/torii-gate.png" alt="" role="presentation" class="w-[220px] md:w-[280px]" />
        <img src="/assets/cloud-formation.png" alt="" role="presentation" class="pointer-events-none absolute -right-4 top-0 w-[80px] opacity-40 animate-[cloud-drift_18s_ease-in-out_infinite]" />
      </div>
    </div>

    <div class="md:w-[60%]">
      <div class="mb-8 flex gap-0">
        <button type="button" data-info-tab="news" aria-selected="true" class="info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-teal text-white transition-all duration-300">
          {home.info.tabNews}
        </button>
        <button type="button" data-info-tab="blogs" aria-selected="false" class="info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-white text-navy-text/60 hover:text-navy-text transition-all duration-300">
          {home.info.tabBlogs}
        </button>
      </div>

      <div data-info-panel="news" class="space-y-0">
        {upcomingEvents.length === 0 ? (
          <p class="text-sm text-navy-text/60 italic px-6 py-5">No upcoming events.</p>
        ) : (
          upcomingEvents.map((event) => (
            <a href={eventsIndexPath} class="group block border-b border-navy-text/10 bg-white px-6 py-5 transition-all duration-300 hover:bg-sky-light/50">
              <p class="mb-1 text-xs tracking-[0.08em] text-navy-text/40">{formatEventDate(event.data.date)}</p>
              <p class="text-sm font-normal leading-relaxed text-navy-text transition-colors duration-300 group-hover:text-teal">{eventTitle(event)}</p>
            </a>
          ))
        )}
      </div>

      <div data-info-panel="blogs" class="space-y-0 hidden">
        {topPosts.map((post) => (
          <a href={`${blogIndexPath}/${post.data.slug}`} class="group block border-b border-navy-text/10 bg-white px-6 py-5 transition-all duration-300 hover:bg-sky-light/50">
            <p class="mb-1 text-xs tracking-[0.08em] text-navy-text/40">{formatDate(post.data.date)}</p>
            <p class="text-sm font-normal leading-relaxed text-navy-text transition-colors duration-300 group-hover:text-teal">{postTitle(post)}</p>
          </a>
        ))}
      </div>

      <div class="mt-6 text-right">
        <a href={blogIndexPath} class="inline-block text-sm tracking-[0.08em] text-navy-text/50 transition-colors duration-300 hover:text-teal">
          {home.info.moreNews}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ============================== SERVICES ============================== -->
<section
  id="services"
  class="relative w-full overflow-hidden bg-white py-20 md:py-28"
>
  <img src="/assets/petal-swirl.png" alt="" role="presentation" class="pointer-events-none absolute -right-20 -top-32 w-[250px] opacity-40 md:-right-10 md:w-[350px]" />
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-12 md:mb-16">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.services.title}
      </h2>
      <p class="mt-3 max-w-[400px] text-sm font-light leading-relaxed text-navy-text/60">
        {home.services.subtitle}
      </p>
    </div>
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 md:gap-8 lg:gap-10">
      {services.map((s) => {
        const detailHref = `/${locale}/services/${s.slug}`;
        return s.image ? (
          <a href={detailHref} class="group cursor-pointer text-center">
            <div class="relative mx-auto mb-4 aspect-square w-full max-w-[180px] overflow-hidden rounded-full md:max-w-[200px] bg-gradient-to-br from-sky-light to-cream">
              <img
                src={s.image}
                alt={s.title}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 rounded-full bg-teal/0 transition-all duration-500 group-hover:bg-teal/20"></div>
            </div>
            <h3 class="font-serif text-sm font-normal uppercase tracking-[0.1em] text-navy-text transition-colors duration-300 group-hover:text-teal md:text-base">
              {s.title}
            </h3>
            <p class="mt-1 text-xs tracking-[0.05em] text-navy-text/40">{s.subtitle}</p>
          </a>
        ) : (
          <a href={detailHref} class="card group block hover:-translate-y-1 text-left">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-sky-light/40 flex items-center justify-center text-xl text-teal/70 transition-transform duration-300 group-hover:scale-110">
                {s.icon}
              </div>
              <h3 class="font-serif text-base text-navy-text leading-snug group-hover:text-teal transition-colors duration-300">
                {s.title}
              </h3>
            </div>
            <p class="text-[11px] text-rose tracking-wider uppercase mb-2">{s.subtitle}</p>
            {s.description && (
              <p class="text-xs text-navy-text/80 leading-relaxed tracking-[0.05em]">
                {s.description}
              </p>
            )}
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================== TESTIMONIALS ============================== -->
<section
  id="testimonials"
  class="relative w-full overflow-hidden bg-gray-section py-20 md:py-28"
>
  <div class="absolute -top-1 left-0 w-full rotate-180">
    <img src="/assets/ocean-waves.png" alt="" role="presentation" class="pointer-events-none w-full opacity-10" style="mask-image: linear-gradient(to bottom, black 0%, transparent 80%); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%);" />
  </div>
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-12 text-center md:mb-16">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-navy-text md:text-4xl">
        {home.testimonials.title}
      </h2>
      <p class="mt-2 font-sans text-sm tracking-[0.15em] text-navy-text/40">
        {home.testimonials.sub}
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {testimonials.map((t) => (
        <div class="relative bg-white px-8 py-10">
          <span class="absolute left-6 top-6 font-serif text-5xl leading-none text-teal/20">&ldquo;</span>
          <p class="relative z-10 mb-6 pt-6 text-sm font-light leading-relaxed text-navy-text/80">{t.quote}</p>
          <p class="text-xs font-normal tracking-[0.15em] text-teal">— {t.name}</p>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/testimonials" class="inline-block text-sm tracking-[0.08em] text-navy-text/50 transition-colors duration-300 hover:text-teal">
        Read all stories →
      </a>
    </div>
  </div>
  <div class="absolute -bottom-1 left-0 w-full">
    <img src="/assets/ocean-waves.png" alt="" role="presentation" class="pointer-events-none w-full opacity-15" style="mask-image: linear-gradient(to top, black 0%, transparent 80%); -webkit-mask-image: linear-gradient(to top, black 0%, transparent 80%);" />
  </div>
</section>

<!-- ============================== STORY (dark) ============================== -->
<section
  id="story"
  data-dark-section
  class="relative w-full overflow-hidden bg-navy-deep py-20 md:py-28"
>
  <img src="/assets/cloud-formation.png" alt="" role="presentation" class="pointer-events-none absolute -left-10 top-[10%] w-[150px] opacity-20 animate-[cloud-drift_18s_ease-in-out_infinite]" />
  <div class="relative z-10 mx-auto flex max-w-[1200px] flex-col items-center gap-12 px-6 md:flex-row md:gap-16 md:px-12 lg:px-8">
    <div class="w-full md:w-[45%]">
      <img src="/assets/story-mountains.png" alt="" role="presentation" class="w-full max-w-[400px]" />
    </div>
    <div class="w-full md:w-[55%]">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-white md:text-4xl">
        {home.story.title}
      </h2>
      <p class="mt-2 text-sm tracking-[0.1em] text-white/40">
        {home.story.sub}
      </p>
      <div class="mt-8 space-y-5">
        {storyParas.map((p) => (
          <p class="text-sm font-light leading-relaxed text-white/80">{p}</p>
        ))}
      </div>
      <p class="mt-8 text-[10px] uppercase tracking-[0.2em] text-white/40">
        {home.story.certEyebrow}
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        {flatCerts.map((cert) => (
          <span class="rounded-full border border-white/20 px-4 py-1.5 text-xs tracking-[0.05em] text-white/60">{cert}</span>
        ))}
      </div>
      <a href={aboutPath} class="mt-8 inline-block text-sm tracking-[0.08em] text-teal-light transition-colors duration-300 hover:text-white">
        Read more →
      </a>
    </div>
  </div>
</section>

<!-- ============================== Q & A (dark) ============================== -->
<section
  id="qa"
  data-dark-section
  class="relative w-full overflow-hidden bg-navy-deep py-20 md:py-28 border-t border-white/5"
>
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <h3 class="mb-8 font-serif text-2xl font-normal uppercase tracking-[0.12em] text-white">
      {home.faqs.title}
    </h3>

    {sortedFaqs.length === 0 ? (
      <p class="text-sm font-light text-white/60 italic">{home.faqs.empty}</p>
    ) : (
      <div class="space-y-3">
        {sortedFaqs.map((f) => (
          <details class="group rounded-md border border-white/10 bg-white/[0.03] [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-4 text-left transition-colors duration-300 hover:bg-white/[0.05]">
              <span class="pr-4 text-sm font-normal tracking-[0.04em] text-white/80">
                {faqQ(f)}
              </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 text-white/40 transition-transform duration-300 group-open:rotate-180"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="border-t border-white/10 px-6 pb-5 pt-4">
              <p class="text-sm font-light leading-relaxed text-white/60 whitespace-pre-line">
                {faqA(f)}
              </p>
            </div>
          </details>
        ))}
      </div>
    )}
  </div>
</section>

<!-- ============================== CONTACT (dark) ============================== -->
<section
  id="contact"
  data-dark-section
  class="relative w-full overflow-hidden bg-navy-deep py-20 md:py-28"
>
  <div class="absolute bottom-0 left-0 w-[280px] overflow-hidden lg:w-[380px]">
    <img src="/assets/lotus-flowers.png" alt="" role="presentation" class="pointer-events-none w-full" />
  </div>
  <div class="relative z-10 mx-auto max-w-[1200px] px-6 md:px-12 lg:px-8">
    <div class="mb-16 md:mb-20">
      <h2 class="font-serif text-3xl font-normal uppercase tracking-[0.15em] text-white md:text-4xl">
        {home.contact.title}
      </h2>
      <p class="mt-2 text-sm tracking-[0.1em] text-white/40">
        {home.contact.sub}
      </p>
      <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-16">
        <div>
          <p class="mb-6 text-sm font-light leading-relaxed text-white/70">
            All sessions are held online via Zoom. I welcome clients from all over the world. Feel free to reach out with any questions or to book your session.
          </p>
          <div class="space-y-3">
            <a href={`mailto:${home.contact.email}`} class="block text-sm tracking-[0.06em] text-teal-light transition-colors duration-300 hover:text-white">
              {home.contact.email}
            </a>
            <div class="flex gap-6 pt-2 text-xs tracking-[0.06em] text-white/50">
              <a href="https://instagram.com/carmennghealing" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-teal-light">Instagram</a>
              <a href="https://youtube.com/@CarmenNgHealing" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-teal-light">YouTube</a>
              <a href="https://open.spotify.com/artist/3dPiiI40Irujqmd4f9atMs" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-teal-light">Spotify</a>
            </div>
          </div>
        </div>
        <div class="flex flex-col items-start justify-center">
          <p class="mb-6 text-sm font-light leading-relaxed text-white/70">
            {home.contact.ctaCopy}
          </p>
          <a href={`mailto:${home.contact.email}?subject=Session%20Booking`} class="inline-block rounded-full bg-coral px-10 py-3.5 text-sm font-normal tracking-[0.1em] text-white shadow-lg shadow-coral/25 transition-all duration-300 hover:bg-coral-dark hover:shadow-xl">
            {home.contact.bookSession}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function activate(name: string) {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-info-tab]');
    tabs.forEach((tab) => {
      const isActive = tab.getAttribute('data-info-tab') === name;
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      tab.className = isActive
        ? 'info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-teal text-white transition-all duration-300'
        : 'info-tab px-8 py-3 text-sm font-normal tracking-[0.1em] rounded-t-lg bg-white text-navy-text/60 hover:text-navy-text transition-all duration-300';
    });
    document.querySelectorAll<HTMLElement>('[data-info-panel]').forEach((panel) => {
      panel.classList.toggle('hidden', panel.getAttribute('data-info-panel') !== name);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('[data-info-tab]').forEach((tab) => {
    tab.addEventListener('click', () => {
      const name = tab.getAttribute('data-info-tab');
      if (name) activate(name);
    });
  });
</script>
